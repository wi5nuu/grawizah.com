# ============================================================
# GRAWIZAH BACKEND — Environment Variables Reference
# Copy to .env.local and fill in your actual values.
# NEVER commit .env.local to git!
# ============================================================

# ── SERVER ──────────────────────────────────────────────────
# Port the Gin HTTP server listens on
PORT=8080

# Environment: "development" | "production"
# CRITICAL: Set to "production" before deploying.
# Controls: mock token bypass (C-02), rate limiter fail strategy (H-05)
GO_ENV=development

# ── DATABASE ─────────────────────────────────────────────────
# Full Supabase connection string (preferred)
# Get from: Supabase Dashboard → Project Settings → Database → Connection String (URI)
# Append ?pgbouncer=true for connection pooler (port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Alternative: individual fields (used only if DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=grawizah

# SSL mode for DB connection [M-05]
# dev: disable | production: require | strict: verify-full
DB_SSL_MODE=disable

# ── SUPABASE ─────────────────────────────────────────────────
# Project URL (no trailing slash)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Public key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key — NEVER expose to frontend
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT Secret — from Supabase Dashboard → Project Settings → API → JWT Secret
# Used to verify HS256-signed tokens from Supabase Auth [C-01]
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-from-dashboard

# Fallback JWT secret for custom-issued tokens
JWT_SECRET=generate_with_openssl_rand_base64_32

# ── AI / GROQ ─────────────────────────────────────────────────
# API Key — get from https://console.groq.com/keys
GROQ_API_KEY=gsk_your_api_key_here

# Base URL (default: https://api.groq.com/openai/v1)
GROQ_API_URL=https://api.groq.com/openai/v1

# Model to use (default: llama-3.1-70b-versatile)
GROQ_MODEL=llama-3.1-70b-versatile

# ── REDIS (Rate Limiting) ────────────────────────────────────
# Upstash Redis REST URL — from https://console.upstash.com/
# In production GO_ENV=production, Redis failure = fail-closed [H-05]
UPSTASH_REDIS_URL=rediss://default:your_token@your-redis.upstash.io:6379

# ── DOCUMENT VAULT ───────────────────────────────────────────
# AES-256-GCM encryption key — MUST be exactly 32 bytes [C-03]
# Generate: openssl rand -hex 16
DOC_ENCRYPTION_KEY=generate-exactly-32-byte-hex-key!!

# Upload directory (relative to binary)
DOC_UPLOAD_DIR=./uploads/documents

# ── WHATSAPP / TWILIO ────────────────────────────────────────
# From https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com
