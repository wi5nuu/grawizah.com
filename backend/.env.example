# ================================
# GRAWIZAH Backend - Environment Variables
# ================================

# Server Configuration
PORT=8080
GO_ENV=development
API_VERSION=v1

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/grawizah?sslmode=disable
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grawizah
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSLMODE=disable
DB_MAX_CONNECTIONS=25
DB_MAX_IDLE_CONNECTIONS=5

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Redis/Upstash
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_token

# Groq AI
GROQ_API_KEY=gsk_your_api_key
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1

# JWT Configuration
JWT_SECRET=your_jwt_secret_min_32_characters
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=your_refresh_secret
REFRESH_TOKEN_EXPIRY=168h

# WhatsApp Business API
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_WEBHOOK_URL=https://your-domain.com/api/whatsapp/webhook

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@grawizah.com

# External APIs
UN_COMTRADE_API_KEY=your_comtrade_key
UN_COMTRADE_API_URL=https://comtradeapi.un.org/data/v1

# Security
ENCRYPTION_KEY=your_32_character_encryption_key
AES_SECRET_KEY=your_aes_256_secret_32_characters
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://grawizah.com

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_FREE_TIER_DAILY=3
RATE_LIMIT_PREMIUM_TIER_DAILY=unlimited

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx
UPLOAD_PATH=./uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_WHATSAPP_BRIDGE=true
ENABLE_MARKET_ALERTS=true
ENABLE_RATE_LIMITING=true

# Monitoring
SENTRY_DSN=your_sentry_dsn
ENABLE_METRICS=true
