# ============================================================
# GRAWIZAH FRONTEND — Environment Variables Reference
# Copy to .env.local and fill in your actual values.
# NEVER commit .env.local to git!
# ============================================================

# ── BACKEND API ──────────────────────────────────────────────
# Base URL of the Go backend (no trailing slash)
# dev: http://localhost:8080 | prod: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── SUPABASE ─────────────────────────────────────────────────
# Project URL — from Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/Public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── APP ──────────────────────────────────────────────────────
# Public URL of this frontend (used for SEO / OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development
