# ================================
# GRAWIZAH - Environment Variables
# ================================

# --------------------------------
# Supabase Configuration
# --------------------------------
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --------------------------------
# Groq AI Configuration
# --------------------------------
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-70b-versatile

# --------------------------------
# Backend API Configuration
# --------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
PORT=8080
GO_ENV=development

# --------------------------------
# Database Configuration
# --------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/grawizah
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grawizah
DB_USER=postgres
DB_PASSWORD=your_db_password

# --------------------------------
# Redis/Upstash Configuration
# --------------------------------
UPSTASH_REDIS_URL=your_upstash_redis_url
UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# --------------------------------
# External Data Sources
# --------------------------------
UN_COMTRADE_API_KEY=your_un_comtrade_api_key

# --------------------------------
# WhatsApp Business API (Twilio)
# --------------------------------
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --------------------------------
# JWT & Authentication
# --------------------------------
JWT_SECRET=your_jwt_secret_key_min_32_characters
JWT_EXPIRY=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRY=7d

# --------------------------------
# Email Configuration (Optional)
# --------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@grawizah.com

# --------------------------------
# File Upload & Storage
# --------------------------------
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx
SUPABASE_STORAGE_BUCKET=documents

# --------------------------------
# Rate Limiting
# --------------------------------
RATE_LIMIT_FREE_TIER=3
RATE_LIMIT_PREMIUM_TIER=unlimited
RATE_LIMIT_WINDOW=86400

# --------------------------------
# Security
# --------------------------------
ENCRYPTION_KEY=your_32_character_encryption_key
AES_SECRET=your_aes_256_secret_key_32_chars

# --------------------------------
# Analytics & Monitoring
# --------------------------------
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
SENTRY_DSN=your_sentry_dsn

# --------------------------------
# Feature Flags
# --------------------------------
ENABLE_AI_FEATURES=true
ENABLE_WHATSAPP_BRIDGE=true
ENABLE_MARKET_ALERTS=true
ENABLE_2FA=true

# --------------------------------
# Development/Production
# --------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Grawizah

